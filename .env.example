# Public Supabase URL — safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://yrzawkqcifuubtltktbk.supabase.co

# Publishable (anon) key. Safe in the browser; gated by RLS on every read.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. NEVER expose to the browser; used only inside Server Actions
# that legitimately need to bypass RLS (admin writes, audit logs, storage proxy).
# The `import "server-only"` directive in src/lib/supabase/admin.ts makes
# leakage a hard build-time error.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — only needed if you run scripts/transcribe-feedback.mjs locally.
# Not consumed by the Next.js app at runtime; never set in Vercel.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
