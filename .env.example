# Watch Alley environment variables
# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.
#
# Supabase project: the-watch-alley (yrzawkqcifuubtltktbk).
# Get keys from https://supabase.com/dashboard/project/yrzawkqcifuubtltktbk/settings/api

# Public URL of the Supabase project. Safe to expose in the browser.
WATCH_ALLEY_SUPABASE_URL=https://yrzawkqcifuubtltktbk.supabase.co

# Publishable (anon) key. Safe to expose in the browser. Read-only by RLS policy.
WATCH_ALLEY_SUPABASE_ANON_KEY=

# Service role key. NEVER expose to the browser. Only used by local sync/seed scripts
# that need to write to the watch_alley.watches table without RLS.
WATCH_ALLEY_SUPABASE_SERVICE_ROLE_KEY=
