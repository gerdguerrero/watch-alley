# Watch Alley environment variables
# Copy this file to `.env.local` and fill in real values. Do NOT commit `.env.local`.
#
# Supabase project: TBD — the original project (trqgzrylysybgipcejwe) was the wrong
# tenant and has been wiped clean of Watch Alley artifacts. Create a new Supabase
# project for Watch Alley, then fill these three values in `.env.local`.
# When you do, also update SUPABASE_URL and SUPABASE_ANON_KEY in scripts/admin.js
# (they are baked in at build time so the static admin page can boot offline).

# Public URL of the Supabase project. Safe to expose in the browser.
WATCH_ALLEY_SUPABASE_URL=https://YOUR-NEW-PROJECT-REF.supabase.co

# Publishable (anon) key. Safe to expose in the browser. Read-only by RLS policy.
WATCH_ALLEY_SUPABASE_ANON_KEY=

# Service role key. NEVER expose to the browser. Only used by local sync scripts
# that need to write to the watch_alley.watches table without RLS.
WATCH_ALLEY_SUPABASE_SERVICE_ROLE_KEY=
