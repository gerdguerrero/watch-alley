# Public Supabase URL - safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://yrzawkqcifuubtltktbk.supabase.co
NEXT_PUBLIC_SITE_URL=https://www.thewatchalley.com

# Publishable (anon) key. Safe in the browser; gated by RLS on every read.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. NEVER expose to the browser; used only inside Server Actions
# that legitimately need to bypass RLS (admin writes, audit logs, storage proxy).
# The `import "server-only"` directive in src/lib/supabase/admin.ts makes
# leakage a hard build-time error.
SUPABASE_SERVICE_ROLE_KEY=

# Optional salt for hashing subscriber/request IP metadata. If unset, the
# server falls back to existing private runtime secrets; raw IPs are never stored.
WATCH_LIST_IP_HASH_SALT=
WATCH_LIST_UNSUBSCRIBE_SECRET=
WATCH_LIST_DELIVERY_HASH_SECRET=

# Newsletter operations. Vercel Cron uses CRON_SECRET automatically; the app
# also accepts NEWSLETTER_CRON_SECRET for manual calls and local testing.
CRON_SECRET=
NEWSLETTER_CRON_SECRET=
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_TEST_RECIPIENT=
GEMINI_API_KEY=
# Opt in to Gemini Google Search grounding for draft context.
NEWSLETTER_ENABLE_WEB_RESEARCH=false

# Admin panel URL token gate. Layer 1 of the admin security stack - read by
# src/middleware.ts. With this set, /admin returns 404 unless the request has
# ?token=<value> or the wa_admin_access cookie. If unset, the middleware lets
# all /admin traffic through (dev fallback). Set in Vercel for production.
ADMIN_ACCESS_TOKEN=

# Server-only Vercel token used by /api/admin/vercel-analytics to read Web
# Analytics usage for thewatchalley.com. Never expose this to the browser.
VERCEL_API_TOKEN=

# Optional - only needed if you run scripts/transcribe-feedback.mjs locally.
# OPENAI_API_KEY is also reserved for future newsletter hero image generation.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
